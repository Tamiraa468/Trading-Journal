generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  BASIC
  PLUS
}

enum Side {
  LONG
  SHORT
}

enum TradeSource {
  MANUAL
  MT5_SYNC
}

enum EmailCodePurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  emailVerifiedAt    DateTime?
  passwordHash      String?
  failedLoginCount  Int      @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  passwordUpdatedAt DateTime?
  plan      Plan     @default(BASIC)
  mt5Login        String?
  mt5Server       String?
  mt5InvestorPass String?
  syncToken       String?   @unique
  syncEnabled     Boolean   @default(false)
  lastSyncAt      DateTime?
  emailCodes EmailCode[]
  trades    Trade[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model EmailCode {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose          EmailCodePurpose
  codeHash         String
  expiresAt        DateTime
  attemptsLeft     Int              @default(5)
  resendNotBefore  DateTime
  sentCount        Int              @default(1)
  consumedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([userId, purpose])
  @@index([expiresAt])
  @@index([purpose, consumedAt])
}

model Trade {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker      String
  side        Side
  entryPrice  Float
  exitPrice   Float
  quantity    Int          @default(100)
  pnl         Float
  date        DateTime
  strategy    String?
  notes       String?
  source      TradeSource  @default(MANUAL)
  mt5DealId   String?      @unique
  swap        Float?       @default(0)
  commission  Float?       @default(0)
  magic       Int?         @default(0)
  reviewed    Boolean      @default(false)
  screenshots Screenshot[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, date(sort: Desc)])
  @@index([userId, ticker])
  @@index([userId, strategy])
}

model Screenshot {
  id        String   @id @default(cuid())
  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([tradeId])
}
